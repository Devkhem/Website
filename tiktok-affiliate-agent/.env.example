# TikTok Developer app settings
# Do not put real secrets in git or shared docs.

TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:8080/tiktok/callback

# OAuth/user authorization result for @thatslife6969
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=
TIKTOK_OPEN_ID=

# Posting mode:
# draft = upload to TikTok inbox for human review/posting
# direct_private = Direct Post self-only/private testing
# direct_public = Direct Post public after API client audit and approval
TIKTOK_POSTING_MODE=draft

